# ===== Обязательно =====
BOT_TOKEN=your_bot_token_here

# ===== PostgreSQL =====
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://musicbot:changeme_strong_password@postgres:5432/musicbot
# Для локальной разработки без Docker:
# DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
# Локально: REDIS_URL=redis://localhost:6379/0

# ===== Webhook (USE_WEBHOOK=false → polling) =====
USE_WEBHOOK=false
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=changeme_random_secret_here
WEBHOOK_PATH=/webhook
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# ===== Admins (через запятую Telegram user_id) =====
ADMIN_IDS=123456789

# ===== Аудио =====
DEFAULT_BITRATE=192
MAX_DURATION=600

# ===== Pyrogram userbot (v1.1 — парсер + Voice Chat) =====
# Получить на https://my.telegram.org → API development tools
PYROGRAM_API_ID=
PYROGRAM_API_HASH=
# Строка сессии (python -m streamer.generate_session)
PYROGRAM_SESSION_STRING=

# ===== Каналы экосистемы (v1.1) =====
TEQUILA_CHANNEL=@your_tequila_channel
FULLMOON_CHANNEL=@your_fullmoon_channel
BLACKROOM_GROUP_ID=-1001234567890

# ===== Spotify API (v1.2 — метаданные) =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== Admin-панель (webapp/admin_api.py) =====
# Если любая из трёх переменных пуста — админка полностью отключена.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ===== Deploy-скрипты (deploy/*.py, archive/*.py) — креды НЕ хранить в коде =====
VPS_HOST=
VPS_USER=root
VPS_PASS=
# Старый сервер (archive/_check_old_server.py), пароли через запятую
OLD_VPS_HOST=
OLD_VPS_PASSWORDS=

# ===== Supabase (deploy/scripts миграций и проверок) =====
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_KEY=
SUPABASE_AI_DB_KEY=
# DSN для скриптов миграции/проверок БД
DATABASE_URL=
OLD_DATABASE_URL=
NEW_DATABASE_URL=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
