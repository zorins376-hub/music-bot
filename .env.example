# ===== Обязательно =====
BOT_TOKEN=your_bot_token_here

# ===== PostgreSQL =====
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://musicbot:changeme_strong_password@postgres:5432/musicbot
# Для локальной разработки без Docker:
# DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
# Локально: REDIS_URL=redis://localhost:6379/0

# ===== Webhook (USE_WEBHOOK=false → polling) =====
USE_WEBHOOK=false
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=changeme_random_secret_here
WEBHOOK_PATH=/webhook
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# ===== Admins (через запятую Telegram user_id) =====
ADMIN_IDS=123456789

# ===== Web admin panel (обязательно в production) =====
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# production | development (в Docker без ENVIRONMENT считается production для admin API)
ENVIRONMENT=development

# TMA debug endpoint POST /api/debug-auth (только dev, false в prod)
WEBAPP_DEBUG_AUTH=false

# ===== Аудио =====
DEFAULT_BITRATE=192
MAX_DURATION=600

# ===== Pyrogram userbot (v1.1 — парсер + Voice Chat) =====
# Получить на https://my.telegram.org → API development tools
PYROGRAM_API_ID=
PYROGRAM_API_HASH=
# Строка сессии (python -m streamer.generate_session)
PYROGRAM_SESSION_STRING=

# ===== Каналы экосистемы (v1.1) =====
TEQUILA_CHANNEL=@your_tequila_channel
FULLMOON_CHANNEL=@your_fullmoon_channel
BLACKROOM_GROUP_ID=-1001234567890

# ===== YouTube (cookies + PO Token) =====
# Netscape cookies.txt as base64 — optional; prefer uploading via /admin ytcookies
# YT_COOKIES=
# bgutil service (docker-compose): http://bgutil-provider:4416
# BGUTIL_POT_BASE_URL=http://bgutil-provider:4416
# YT_COOKIE_ALERT_TELEGRAM=true
# Residential proxy for YouTube on datacenter VPS (also passed to bgutil-provider)
# Bright Data: CP → Access Parameters → ONE URL (zone UUID is NOT auth)
# YOUTUBE_PROXY=http://brd-customer-CUSTOMER-zone-ZONE:PASSWORD@brd.superproxy.io:22225
# YOUTUBE_PROXY=socks5://user:pass@host:port
# PROXY_POOL=socks5://host1:port,socks5://host2:port

# ===== Spotify API (v1.2 — метаданные) =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
