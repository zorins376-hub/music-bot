# ═══════════════════════════════════════════════════════════════════════════
# Music Bot — VPS-Optimized Environment
# ═══════════════════════════════════════════════════════════════════════════
# Для мощных выделенных серверов (4+ CPU, 8GB+ RAM)

# ===== Bot (ОБЯЗАТЕЛЬНО) =====
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ===== Database (локальный PostgreSQL с пулингом) =====
DATABASE_URL=postgresql+asyncpg://musicbot:changeme@postgres:5432/musicbot
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Webhook (polling для VPS) =====
USE_WEBHOOK=false
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# ===== Admins =====
ADMIN_IDS=
ADMIN_USERNAMES=Tequilasunshine1,Kg_1988hp

# ===== Admin Panel Token =====
ADMIN_TOKEN=musicbot-admin-secret-2026

# ===== Audio =====
DEFAULT_BITRATE=192
MAX_DURATION=600

# ═══════════════════════════════════════════════════════════════════════════
# VPS-OPTIMIZED SETTINGS (было ограничено для Railway)
# ═══════════════════════════════════════════════════════════════════════════

# ── Thread Pool (download workers) ──
YTDL_WORKERS=8                      # Railway: 4 → VPS: 8-12
YTDL_MAX_WORKERS_MULTIPLIER=4       # MAX_WORKERS = 8*4 = 32
YTDL_CONCURRENT_FRAGMENTS=8         # parallel fragments per download

# ── HTTP Connection Pool ──
HTTP_POOL_CONNECTIONS=100           # TCP connection pool
HTTP_POOL_KEEPALIVE=30              # keepalive seconds
HTTP_CONNECT_TIMEOUT=10             # connection timeout
HTTP_READ_TIMEOUT=60                # read timeout

# ── Database Pool (for local PG) ──
DB_POOL_SIZE=20                     # connection pool size
DB_MAX_OVERFLOW=30                  # extra connections
DB_POOL_TIMEOUT=30                  # wait for connection
DB_COMMAND_TIMEOUT=30               # query timeout (was 15)
DB_CONNECT_TIMEOUT=60               # connection timeout (was 30)

# ── Prometheus Metrics ──
METRICS_PORT=9090                   # Railway: 0 (disabled) → VPS: 9090

# ═══════════════════════════════════════════════════════════════════════════
# API KEYS (заполнить)
# ═══════════════════════════════════════════════════════════════════════════

# ===== Spotify API =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== Yandex Music =====
YANDEX_MUSIC_TOKEN=
YANDEX_TOKENS=

# ===== VK Music =====
VK_TOKEN=

# ===== OpenAI (AI плейлисты) =====
OPENAI_API_KEY=

# ===== YouTube cookies (base64) =====
YT_COOKIES=

# ===== Proxy pool =====
PROXY_POOL=

# ===== Sentry =====
SENTRY_DSN=

# ===== Genius (lyrics) =====
GENIUS_TOKEN=

# ===== Supabase AI =====
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_AI_ENABLED=true

# ===== TMA Player =====
TMA_URL=

# ===== Каналы =====
TEQUILA_CHANNEL=
FULLMOON_CHANNEL=
BLACKROOM_GROUP_ID=

# ═══════════════════════════════════════════════════════════════════════════
# ML Recommendations (опционально — можно включить на VPS)
# ═══════════════════════════════════════════════════════════════════════════
ML_ENABLED=false                    # локальный ML (включить если нужен fallback)
ML_AB_TEST_ENABLED=false
