# Local deploy credentials — copy to deploy/.env (gitignored)
# Never commit real passwords or tokens.

# Example VPS (replace with your host)
DEPLOY_SSH_HOST=5.75.182.82
DEPLOY_SSH_USER=root

# Prefer SSH key auth
DEPLOY_SSH_KEY_PATH=~/.ssh/id_ed25519

# Password auth (only if no key)
# DEPLOY_SSH_PASSWORD=

# Optional: remote project path (defaults vary per script)
# DEPLOY_PROJECT_DIR=/opt/music-bot

# Optional: git repo URL for fresh deploy (ssh_deploy.py)
# DEPLOY_REPO_URL=https://github.com/your-org/music-bot.git
