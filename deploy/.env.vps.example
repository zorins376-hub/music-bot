# Music Bot — VPS-Optimized Environment Template
# Copy to deploy/.env.vps.local (ignored by git) and fill secrets.

BOT_TOKEN=YOUR_BOT_TOKEN_HERE

DATABASE_URL=postgresql+asyncpg://musicbot:changeme@postgres:5432/musicbot
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

USE_WEBHOOK=false
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

ADMIN_IDS=
ADMIN_USERNAMES=
ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
ADMIN_USERNAME=CHANGE_ME_ADMIN_USERNAME
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_ADMIN_SESSION_SECRET

DEFAULT_BITRATE=192
MAX_DURATION=600

YTDL_WORKERS=8
YTDL_MAX_WORKERS_MULTIPLIER=4
YTDL_CONCURRENT_FRAGMENTS=8

HTTP_POOL_CONNECTIONS=100
HTTP_POOL_KEEPALIVE=30
HTTP_CONNECT_TIMEOUT=10
HTTP_READ_TIMEOUT=60

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_COMMAND_TIMEOUT=30
DB_CONNECT_TIMEOUT=60

METRICS_PORT=9090

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YANDEX_MUSIC_TOKEN=
YANDEX_TOKENS=
VK_TOKEN=
OPENAI_API_KEY=
YT_COOKIES=
PROXY_POOL=
SENTRY_DSN=
GENIUS_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_AI_ENABLED=true
TMA_URL=
TEQUILA_CHANNEL=
FULLMOON_CHANNEL=
BLACKROOM_GROUP_ID=

ML_ENABLED=false
ML_AB_TEST_ENABLED=false
