# Music Bot — Production Environment Template
# Copy to deploy/.env.production.local (ignored by git) and fill secrets.

BOT_TOKEN=YOUR_BOT_TOKEN_HERE

DATABASE_URL=postgresql+asyncpg://musicbot:changeme@postgres:5432/musicbot
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

USE_WEBHOOK=false
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

ADMIN_IDS=
ADMIN_USERNAMES=
ADMIN_USERNAME=CHANGE_ME_ADMIN_USERNAME
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_ADMIN_SESSION_SECRET

DEFAULT_BITRATE=192
MAX_DURATION=600

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YANDEX_MUSIC_TOKEN=
YANDEX_TOKENS=
VK_TOKEN=
OPENAI_API_KEY=
YT_COOKIES=
PROXY_POOL=
SENTRY_DSN=
GENIUS_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_AI_ENABLED=false
TMA_URL=
TEQUILA_CHANNEL=
FULLMOON_CHANNEL=
BLACKROOM_GROUP_ID=
