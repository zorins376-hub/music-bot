# Music Bot — Production Environment Template
# Copy to deploy/.env.production.local (ignored by git) and fill secrets.

BOT_TOKEN=YOUR_BOT_TOKEN_HERE

DATABASE_URL=postgresql+asyncpg://musicbot:changeme@postgres:5432/musicbot
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

USE_WEBHOOK=false
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

ADMIN_IDS=
ADMIN_USERNAMES=
ADMIN_USERNAME=CHANGE_ME_ADMIN_USERNAME
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_ADMIN_SESSION_SECRET

DEFAULT_BITRATE=192
MAX_DURATION=600

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YANDEX_MUSIC_TOKEN=
YANDEX_TOKENS=
VK_TOKEN=
OPENAI_API_KEY=
YT_COOKIES=
BGUTIL_POT_BASE_URL=http://bgutil-provider:4416
# --- Bright Data: CP → Access Parameters → ONE line (zone UUID is NOT auth) ---
# YOUTUBE_PROXY=http://brd-customer-CUSTOMER-zone-ZONE:PASSWORD@brd.superproxy.io:22225
# YT_COOKIE_ALERT_TELEGRAM=true
PROXY_POOL=
SENTRY_DSN=
GENIUS_TOKEN=
# Optional; lyrics APIs fall back to YOUTUBE_PROXY when unset
GENIUS_PROXY_URL=
# Get a free key at https://developer.musixmatch.com/ (Musixmatch returns 401 without it)
MUSIXMATCH_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_AI_ENABLED=false
TMA_URL=
TEQUILA_CHANNEL=
FULLMOON_CHANNEL=
BLACKROOM_GROUP_ID=
