# ═══════════════════════════════════════════════════════════════════════════
# Music Bot — Production Environment (Docker)
# ═══════════════════════════════════════════════════════════════════════════

# ===== Bot (ОБЯЗАТЕЛЬНО) =====
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ===== Database (PostgreSQL в Docker) =====
DATABASE_URL=postgresql+asyncpg://musicbot:changeme@postgres:5432/musicbot
POSTGRES_DB=musicbot
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=changeme

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Webhook (polling для VPS) =====
USE_WEBHOOK=false
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# ===== Admins =====
ADMIN_IDS=
ADMIN_USERNAMES=Tequilasunshine1,Kg_1988hp

# ===== Audio =====
DEFAULT_BITRATE=192
MAX_DURATION=600

# ===== Spotify API =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== Yandex Music =====
YANDEX_MUSIC_TOKEN=
YANDEX_TOKENS=

# ===== VK Music =====
VK_TOKEN=

# ===== OpenAI (AI плейлисты) =====
OPENAI_API_KEY=

# ===== YouTube cookies (base64) =====
YT_COOKIES=

# ===== Proxy pool =====
PROXY_POOL=

# ===== Sentry =====
SENTRY_DSN=

# ===== Genius (lyrics) =====
GENIUS_TOKEN=

# ===== Supabase AI =====
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_AI_ENABLED=false

# ===== TMA Player =====
TMA_URL=

# ===== Каналы =====
TEQUILA_CHANNEL=
FULLMOON_CHANNEL=
BLACKROOM_GROUP_ID=
